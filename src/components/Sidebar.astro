---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const docs = await getCollection('docs');
const sorted = docs.sort((a, b) => a.data.order - b.data.order);
---

<aside class="w-48 lg:w-56 shrink-0 border-r border-sb-border flex flex-col overflow-y-auto hidden md:flex">
  <div class="px-4 py-3 border-b border-sb-border flex items-center justify-between">
    <span class="text-[9px] font-terminal uppercase tracking-[.2em] text-sb-dim">Sections</span>
    <span class="text-[8px] font-terminal text-sb-dim tracking-wider">{sorted.length} DOCS</span>
  </div>
  <nav class="flex flex-col py-1">
    {sorted.map((doc) => {
      const slug = doc.id.replace(/\.md$/, '');
      const isActive = slug === currentSlug;
      return (
        <a
          href={`/${slug}`}
          class:list={[
            'group text-left px-4 py-2.5 flex items-center gap-3 transition-all duration-75 border-l-2',
            isActive
              ? 'bg-sb-surface'
              : 'border-transparent hover:bg-sb-surface/40 hover:border-sb-border',
          ]}
          style={isActive ? `border-color: ${doc.data.color}; box-shadow: inset 3px 0 12px -6px ${doc.data.color}33` : ''}
        >
          <span
            class:list={[
              'text-[9px] font-terminal shrink-0 transition-colors duration-75',
              isActive ? '' : 'opacity-40 group-hover:opacity-70',
            ]}
            style={`color: ${doc.data.color}`}
          >
            {doc.data.tag}
          </span>
          <span
            class:list={[
              'text-[11px] font-terminal leading-tight transition-colors duration-75',
              isActive ? 'text-sb-text-1' : 'text-sb-muted group-hover:text-sb-text-2',
            ]}
          >
            {doc.data.title}
          </span>
        </a>
      );
    })}
  </nav>

  <div class="mt-auto p-4 border-t border-sb-border">
    <div class="border border-sb-border bg-sb-surface p-3">
      <div class="text-[9px] font-terminal text-sb-dim mb-2 tracking-wider">INSTALL</div>
      <div class="text-[11px] font-terminal text-sb-muted">
        <span class="text-sb-dim">$</span> npm i -D @stackbilt/cli
      </div>
    </div>
  </div>
</aside>
