---
import { getNavigation } from '../lib/navigation';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const { sections } = await getNavigation();
---

<aside class="w-52 lg:w-60 shrink-0 border-r border-sb-border flex flex-col overflow-y-auto hidden md:flex sidebar-fade-in">
  <div class="px-5 py-4 border-b border-sb-border">
    <span class="text-[9px] font-terminal uppercase tracking-[.2em] text-sb-dim">Documentation</span>
  </div>

  <nav class="flex-1 overflow-y-auto py-1 sidebar-scroll">
    {sections.map((section, sIdx) => {
      const sectionHasActive = section.items.some(item => item.slug === currentSlug);
      return (
        <div class:list={['pb-1', sIdx > 0 && 'border-t border-sb-border/40 mt-1']}>
          <!-- Section header -->
          <div class="px-5 pt-4 pb-2 flex items-center gap-2">
            <span
              class="w-1.5 h-1.5 rounded-full shrink-0"
              style={`background: ${section.color}; box-shadow: 0 0 ${sectionHasActive ? '8' : '4'}px ${section.color}${sectionHasActive ? '60' : '30'}`}
            />
            <span
              class="text-[9px] font-terminal uppercase tracking-[.15em]"
              style={`color: ${section.color}; opacity: ${sectionHasActive ? '0.9' : '0.5'}`}
            >
              {section.label}
            </span>
            <span class="text-[8px] font-terminal text-sb-dim/40 ml-auto">{section.items.length}</span>
          </div>

          <!-- Section items -->
          {section.items.map((item) => {
            const isActive = item.slug === currentSlug;
            return (
              <a
                href={`/${item.slug}`}
                class:list={[
                  'group flex items-center gap-3 px-5 py-2 transition-all duration-75 border-l-2 ml-3',
                  isActive
                    ? 'bg-sb-surface/80'
                    : 'border-transparent hover:bg-sb-surface/30 hover:border-sb-border',
                ]}
                style={isActive ? `border-color: ${item.color}; box-shadow: inset 4px 0 16px -8px ${item.color}30` : ''}
              >
                <span
                  class:list={[
                    'text-[9px] font-terminal shrink-0 w-4 text-right tabular-nums transition-all duration-75',
                    isActive ? '' : 'opacity-25 group-hover:opacity-50',
                  ]}
                  style={`color: ${item.color}`}
                >
                  {item.tag}
                </span>
                <span
                  class:list={[
                    'text-[11px] font-terminal leading-tight transition-colors duration-75 truncate',
                    isActive ? 'text-sb-text-1' : 'text-sb-muted group-hover:text-sb-text-2',
                  ]}
                >
                  {item.title}
                </span>
              </a>
            );
          })}
        </div>
      );
    })}
  </nav>

  <div class="p-4 border-t border-sb-border mt-auto">
    <div class="border border-sb-border/60 bg-sb-surface/40 p-3">
      <div class="text-[9px] font-terminal text-sb-dim mb-2 tracking-wider uppercase">Quick Start</div>
      <div class="text-[11px] font-terminal text-sb-muted">
        <span class="text-sb-dim select-none">$ </span><span class="text-sb-amber/60">npm</span> i -D @stackbilt/cli
      </div>
    </div>
  </div>
</aside>
