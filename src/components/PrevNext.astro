---
import { getNavigation } from '../lib/navigation';

interface Props {
  currentOrder: number;
}

const { currentOrder } = Astro.props;
const { flat } = await getNavigation();

const currentIdx = flat.findIndex((d) => d.order === currentOrder);
const prev = currentIdx > 0 ? flat[currentIdx - 1] : null;
const next = currentIdx < flat.length - 1 ? flat[currentIdx + 1] : null;
---

<div class="px-8 pb-8 max-w-3xl">
  <div class="grid grid-cols-2 gap-3 border-t border-sb-border pt-6">
    {prev ? (
      <a
        href={`/${prev.slug}`}
        class="group border border-sb-border/50 hover:border-sb-border p-4 transition-all duration-100 hover:bg-sb-surface/30"
      >
        <div class="text-[9px] font-terminal text-sb-dim tracking-wider mb-2 flex items-center gap-1.5">
          <span class="group-hover:text-sb-amber transition-colors duration-75">&larr;</span>
          <span>PREVIOUS</span>
        </div>
        <div class="text-[11px] font-terminal text-sb-muted group-hover:text-sb-text-2 transition-colors duration-75 leading-tight">
          {prev.title}
        </div>
        <div class="mt-1.5 flex items-center gap-1.5">
          <span class="w-1 h-1 rounded-full" style={`background: ${prev.color}`} />
          <span class="text-[8px] font-terminal text-sb-dim/50 uppercase tracking-wider">{prev.tag}</span>
        </div>
      </a>
    ) : (
      <div />
    )}
    {next ? (
      <a
        href={`/${next.slug}`}
        class="group border border-sb-border/50 hover:border-sb-border p-4 transition-all duration-100 hover:bg-sb-surface/30 text-right"
      >
        <div class="text-[9px] font-terminal text-sb-dim tracking-wider mb-2 flex items-center gap-1.5 justify-end">
          <span>NEXT</span>
          <span class="group-hover:text-sb-amber transition-colors duration-75">&rarr;</span>
        </div>
        <div class="text-[11px] font-terminal text-sb-muted group-hover:text-sb-text-2 transition-colors duration-75 leading-tight">
          {next.title}
        </div>
        <div class="mt-1.5 flex items-center gap-1.5 justify-end">
          <span class="text-[8px] font-terminal text-sb-dim/50 uppercase tracking-wider">{next.tag}</span>
          <span class="w-1 h-1 rounded-full" style={`background: ${next.color}`} />
        </div>
      </a>
    ) : (
      <a
        href="https://stackbilt.dev"
        class="group border border-sb-border/50 hover:border-sb-border p-4 transition-all duration-100 hover:bg-sb-surface/30 text-right"
      >
        <div class="text-[9px] font-terminal text-sb-dim tracking-wider mb-2 flex items-center gap-1.5 justify-end">
          <span>EXIT</span>
          <span class="group-hover:text-sb-amber transition-colors duration-75">&rarr;</span>
        </div>
        <div class="text-[11px] font-terminal text-sb-muted group-hover:text-sb-text-2 transition-colors duration-75 leading-tight">
          Back to StackBilt
        </div>
      </a>
    )}
  </div>
</div>
