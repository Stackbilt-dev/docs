---
import { getNavigation } from '../lib/navigation';

const { sections } = await getNavigation();
const searchData = sections.flatMap(section =>
  section.items.map(item => ({
    ...item,
    sectionLabel: section.label,
    sectionColor: section.color,
  }))
);
---

<div id="search-overlay" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>

  <!-- Dialog -->
  <div class="absolute inset-x-0 top-[12vh] mx-auto w-full max-w-lg px-4">
    <div class="bg-sb-bg border border-sb-border shadow-2xl shadow-black/60 search-dialog">
      <!-- Input row -->
      <div class="flex items-center gap-3 border-b border-sb-border px-4 py-3">
        <span class="text-sb-amber/40 text-[11px] font-terminal shrink-0">&gt;_</span>
        <input
          id="search-input"
          type="text"
          placeholder="Search docs..."
          autocomplete="off"
          spellcheck="false"
          class="flex-1 bg-transparent text-sm font-terminal text-sb-text-1 placeholder:text-sb-dim/60 outline-none caret-sb-amber"
        />
        <kbd class="text-[9px] font-terminal text-sb-dim border border-sb-border px-1.5 py-0.5 leading-none">ESC</kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[45vh] overflow-y-auto">
        <!-- Populated by script -->
      </div>

      <!-- Footer -->
      <div class="border-t border-sb-border px-4 py-2 flex items-center gap-4 text-[9px] font-terminal text-sb-dim/60 tracking-wider">
        <span><kbd class="border border-sb-border/60 px-1 py-0.5 mr-1">&uarr;</kbd><kbd class="border border-sb-border/60 px-1 py-0.5">&darr;</kbd> Navigate</span>
        <span><kbd class="border border-sb-border/60 px-1 py-0.5">RET</kbd> Open</span>
        <span class="ml-auto"><kbd class="border border-sb-border/60 px-1 py-0.5">/</kbd> Search</span>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ searchData }}>
  const overlay = document.getElementById('search-overlay');
  const backdrop = document.getElementById('search-backdrop');
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  let activeIdx = 0;
  let filteredItems = [...searchData];

  function open() {
    overlay.classList.remove('hidden');
    input.value = '';
    activeIdx = 0;
    render(searchData);
    requestAnimationFrame(() => input.focus());
  }

  function close() {
    overlay.classList.add('hidden');
    input.blur();
  }

  function render(items) {
    filteredItems = items;
    if (items.length === 0) {
      results.innerHTML = `<div class="px-4 py-8 text-center text-[11px] font-terminal text-sb-dim/50">NO RESULTS</div>`;
      return;
    }

    let html = '';
    let lastSection = '';
    items.forEach((item, i) => {
      if (item.sectionLabel !== lastSection) {
        lastSection = item.sectionLabel;
        html += `<div class="px-4 pt-3 pb-1 flex items-center gap-2">
          <span class="w-1 h-1 rounded-full" style="background:${item.sectionColor}"></span>
          <span class="text-[8px] font-terminal uppercase tracking-[.15em]" style="color:${item.sectionColor};opacity:0.6">${item.sectionLabel}</span>
        </div>`;
      }
      const isActive = i === activeIdx;
      html += `<a href="/${item.slug}" class="search-item flex items-center gap-3 px-4 py-2.5 transition-all duration-75 border-l-2 ${isActive ? 'bg-sb-surface/80 border-sb-amber' : 'border-transparent hover:bg-sb-surface/40'}" data-idx="${i}">
        <span class="text-[9px] font-terminal shrink-0 w-4 text-right" style="color:${item.color};opacity:${isActive ? '1' : '0.4'}">${item.tag}</span>
        <span class="text-[11px] font-terminal ${isActive ? 'text-sb-text-1' : 'text-sb-muted'} truncate">${item.title}</span>
      </a>`;
    });
    results.innerHTML = html;
  }

  function setActive(idx) {
    activeIdx = Math.max(0, Math.min(idx, filteredItems.length - 1));
    render(filteredItems);
    const el = results.querySelector(`[data-idx="${activeIdx}"]`);
    if (el) el.scrollIntoView({ block: 'nearest' });
  }

  document.addEventListener('keydown', (e) => {
    if ((e.key === '/' || (e.key === 'k' && (e.metaKey || e.ctrlKey))) && overlay.classList.contains('hidden')) {
      if (document.activeElement?.tagName === 'INPUT' || document.activeElement?.tagName === 'TEXTAREA') return;
      e.preventDefault();
      open();
      return;
    }

    if (overlay.classList.contains('hidden')) return;

    if (e.key === 'Escape') {
      e.preventDefault();
      close();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(activeIdx + 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(activeIdx - 1);
    } else if (e.key === 'Enter' && filteredItems.length > 0) {
      e.preventDefault();
      window.location.href = '/' + filteredItems[activeIdx].slug;
    }
  });

  backdrop?.addEventListener('click', close);

  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    if (!q) {
      activeIdx = 0;
      render(searchData);
      return;
    }
    const filtered = searchData.filter(
      (item) =>
        item.title.toLowerCase().includes(q) ||
        item.sectionLabel.toLowerCase().includes(q) ||
        item.tag.toLowerCase().includes(q)
    );
    activeIdx = 0;
    render(filtered);
  });

  window.__searchOpen = open;
</script>
