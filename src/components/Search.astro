---
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
const searchData = docs
  .sort((a, b) => a.data.order - b.data.order)
  .map((doc) => ({
    slug: doc.id.replace(/\.md$/, ''),
    title: doc.data.title,
    tag: doc.data.tag,
    color: doc.data.color,
    section: doc.data.section,
  }));
---

<div id="search-overlay" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Dialog -->
  <div class="absolute inset-x-0 top-[15vh] mx-auto w-full max-w-md px-4">
    <div class="bg-sb-bg border border-sb-border shadow-2xl shadow-black/50">
      <!-- Input row -->
      <div class="flex items-center gap-3 border-b border-sb-border px-4 py-3">
        <span class="text-sb-dim text-[11px] font-terminal shrink-0">&gt;_</span>
        <input
          id="search-input"
          type="text"
          placeholder="Search docs..."
          autocomplete="off"
          spellcheck="false"
          class="flex-1 bg-transparent text-sm font-terminal text-sb-text-1 placeholder:text-sb-dim outline-none caret-sb-amber"
        />
        <kbd class="text-[9px] font-terminal text-sb-dim border border-sb-border px-1.5 py-0.5 leading-none">ESC</kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[40vh] overflow-y-auto">
        <!-- Populated by script -->
      </div>

      <!-- Footer -->
      <div class="border-t border-sb-border px-4 py-2 flex items-center gap-4 text-[9px] font-terminal text-sb-dim tracking-wider">
        <span><kbd class="border border-sb-border px-1 py-0.5 mr-1">&uarr;</kbd><kbd class="border border-sb-border px-1 py-0.5">↓</kbd> NAVIGATE</span>
        <span><kbd class="border border-sb-border px-1 py-0.5">RET</kbd> OPEN</span>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ searchData }}>
  const overlay = document.getElementById('search-overlay');
  const backdrop = document.getElementById('search-backdrop');
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  let activeIdx = 0;
  let filteredItems = [...searchData];

  function open() {
    overlay.classList.remove('hidden');
    input.value = '';
    activeIdx = 0;
    render(searchData);
    requestAnimationFrame(() => input.focus());
  }

  function close() {
    overlay.classList.add('hidden');
    input.blur();
  }

  function render(items) {
    filteredItems = items;
    if (items.length === 0) {
      results.innerHTML = `<div class="px-4 py-6 text-center text-[11px] font-terminal text-sb-dim">NO RESULTS</div>`;
      return;
    }
    results.innerHTML = items
      .map(
        (item, i) =>
          `<a href="/${item.slug}" class="search-item flex items-center gap-3 px-4 py-3 transition-colors duration-75 border-l-2 ${i === activeIdx ? 'bg-sb-surface border-sb-amber' : 'border-transparent hover:bg-sb-surface/60'}" data-idx="${i}">
            <span class="text-[9px] font-terminal shrink-0" style="color:${item.color}">${item.tag}</span>
            <span class="text-[11px] font-terminal ${i === activeIdx ? 'text-sb-text-1' : 'text-sb-muted'}">${item.title}</span>
            <span class="ml-auto text-[9px] font-terminal text-sb-dim tracking-wider uppercase">${item.section}</span>
          </a>`
      )
      .join('');
  }

  function setActive(idx) {
    activeIdx = Math.max(0, Math.min(idx, filteredItems.length - 1));
    render(filteredItems);
    const el = results.querySelector(`[data-idx="${activeIdx}"]`);
    if (el) el.scrollIntoView({ block: 'nearest' });
  }

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    // Open: / or Cmd+K (only when overlay is hidden)
    if ((e.key === '/' || (e.key === 'k' && (e.metaKey || e.ctrlKey))) && overlay.classList.contains('hidden')) {
      if (document.activeElement?.tagName === 'INPUT' || document.activeElement?.tagName === 'TEXTAREA') return;
      e.preventDefault();
      open();
      return;
    }

    if (overlay.classList.contains('hidden')) return;

    if (e.key === 'Escape') {
      e.preventDefault();
      close();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(activeIdx + 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(activeIdx - 1);
    } else if (e.key === 'Enter' && filteredItems.length > 0) {
      e.preventDefault();
      window.location.href = '/' + filteredItems[activeIdx].slug;
    }
  });

  // Close on backdrop click
  backdrop?.addEventListener('click', close);

  // Filter on input
  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    if (!q) {
      activeIdx = 0;
      render(searchData);
      return;
    }
    const filtered = searchData.filter(
      (item) =>
        item.title.toLowerCase().includes(q) ||
        item.section.toLowerCase().includes(q) ||
        item.tag.toLowerCase().includes(q)
    );
    activeIdx = 0;
    render(filtered);
  });

  // Expose open for the nav button
  window.__searchOpen = open;
</script>
