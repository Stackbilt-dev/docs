---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{toc.length > 0 && (
  <nav class="hidden xl:block w-48 shrink-0 sticky top-0 self-start py-8 pr-4">
    <div class="text-[9px] font-terminal uppercase tracking-[.2em] text-sb-dim mb-3">
      On this page
    </div>
    <ul class="flex flex-col gap-1.5">
      {toc.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'text-[11px] font-terminal leading-tight transition-colors duration-75 hover:text-sb-amber block',
              heading.depth === 2 ? 'text-sb-muted' : 'text-sb-dim pl-3',
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
