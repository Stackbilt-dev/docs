---
import type { MarkdownHeading } from 'astro';
import { getNavigation } from '../lib/navigation';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PrevNext from '../components/PrevNext.astro';
import Search from '../components/Search.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  tag: string;
  color: string;
  order: number;
  slug: string;
  section: string;
  headings: MarkdownHeading[];
}

const { title, description, tag, color, order, slug, section, headings } = Astro.props;
const { sections } = await getNavigation();

const metaDescription = description || `${title} — Charter CLI and StackBilt platform documentation.`;
const canonicalUrl = `https://docs.stackbilt.dev/${slug}`;
const pageTitle = `${title} — Docs by Stackbilt`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />

    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-T3MSE40BWF"></script>
    <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-T3MSE40BWF');</script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Docs by Stackbilt" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TechArticle",
      "headline": title,
      "description": metaDescription,
      "url": canonicalUrl,
      "publisher": {
        "@type": "Organization",
        "name": "Stackbilt",
        "url": "https://stackbilt.dev"
      }
    })} />
  </head>
  <body class="h-screen w-screen bg-sb-bg text-sb-text-2 font-body flex flex-col overflow-hidden">
    <!-- Ambient grid -->
    <div class="fixed inset-0 pointer-events-none ambient-grid" />

    <!-- Search overlay -->
    <Search />

    <!-- Top bar -->
    <nav class="relative z-10 border-b border-sb-border px-6 py-3 flex items-center justify-between font-terminal shrink-0">
      <div class="flex items-center gap-4">
        <a
          href="https://stackbilt.dev"
          class="flex items-center gap-2 text-[11px] text-sb-muted hover:text-sb-amber transition-colors duration-75 tracking-wider"
        >
          <span class="text-[10px]">&larr;</span>
          <span>STACKBILT</span>
        </a>
        <span class="text-sb-border">/</span>
        <a href="/" class="text-[11px] text-sb-text-2 tracking-wider hover:text-sb-text-1 transition-colors duration-75">DOCS</a>
      </div>
      <div class="flex items-center gap-4 text-[10px] text-sb-dim">
        <!-- Search trigger (desktop) -->
        <button
          id="search-trigger"
          class="hidden sm:flex items-center gap-2 hover:text-sb-amber transition-colors duration-75 tracking-wider cursor-pointer"
        >
          <span>SEARCH</span>
          <kbd class="border border-sb-border px-1 py-0.5 text-[8px] leading-none">/</kbd>
        </button>
        <a
          href="https://blog.stackbilt.dev"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:block hover:text-sb-amber transition-colors duration-75 tracking-wider"
        >
          BLOG
        </a>
        <a
          href="https://github.com/Stackbilt-dev/charter"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:block hover:text-sb-amber transition-colors duration-75 tracking-wider"
        >
          GITHUB
        </a>
        <a
          href="https://www.npmjs.com/package/@stackbilt/cli"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:block hover:text-sb-amber transition-colors duration-75 tracking-wider"
        >
          NPM
        </a>
        <!-- Search trigger (mobile) -->
        <button
          id="search-trigger-mobile"
          class="sm:hidden flex items-center hover:text-sb-amber transition-colors duration-75 cursor-pointer"
        >
          <kbd class="border border-sb-border px-1.5 py-0.5 text-[9px] leading-none">/</kbd>
        </button>
      </div>
    </nav>

    <!-- Body: sidebar + content + ToC -->
    <div class="relative z-10 flex flex-1 min-h-0 overflow-hidden">
      <!-- Mobile nav toggle -->
      <input type="checkbox" id="mobile-nav" class="peer hidden" />
      <label
        for="mobile-nav"
        class="md:hidden fixed bottom-4 left-4 z-50 bg-sb-surface border border-sb-border rounded px-3 py-2 text-[11px] font-terminal text-sb-muted hover:text-sb-amber cursor-pointer transition-colors mobile-menu-btn"
      >
        MENU
      </label>
      <!-- Mobile sidebar overlay -->
      <div class="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm hidden peer-checked:flex md:hidden">
        <label for="mobile-nav" class="absolute inset-0 cursor-pointer" />
        <aside class="relative z-50 w-72 h-full bg-sb-bg border-r border-sb-border overflow-y-auto flex flex-col mobile-sidebar">
          <div class="px-5 py-4 border-b border-sb-border flex items-center justify-between">
            <span class="text-[9px] font-terminal uppercase tracking-[.2em] text-sb-dim">Documentation</span>
            <label for="mobile-nav" class="text-sb-muted hover:text-sb-amber cursor-pointer text-sm leading-none">&times;</label>
          </div>
          <nav class="flex-1 overflow-y-auto py-1">
            {sections.map((sect, sIdx) => (
              <div class:list={['pb-1', sIdx > 0 && 'border-t border-sb-border/40 mt-1']}>
                <div class="px-5 pt-4 pb-2 flex items-center gap-2">
                  <span
                    class="w-1.5 h-1.5 rounded-full shrink-0"
                    style={`background: ${sect.color}; box-shadow: 0 0 6px ${sect.color}40`}
                  />
                  <span
                    class="text-[9px] font-terminal uppercase tracking-[.15em]"
                    style={`color: ${sect.color}; opacity: 0.7`}
                  >
                    {sect.label}
                  </span>
                </div>
                {sect.items.map((item) => {
                  const isActive = item.slug === slug;
                  return (
                    <a
                      href={`/${item.slug}`}
                      class:list={[
                        'group flex items-center gap-3 px-5 py-3 transition-all duration-75 border-l-2 ml-3',
                        isActive
                          ? 'bg-sb-surface/80'
                          : 'border-transparent hover:bg-sb-surface/30',
                      ]}
                      style={isActive ? `border-color: ${item.color}; box-shadow: inset 4px 0 16px -8px ${item.color}30` : ''}
                    >
                      <span
                        class:list={[
                          'text-[9px] font-terminal shrink-0 w-4 text-right',
                          isActive ? '' : 'opacity-30',
                        ]}
                        style={`color: ${item.color}`}
                      >
                        {item.tag}
                      </span>
                      <span
                        class:list={[
                          'text-[12px] font-terminal leading-tight',
                          isActive ? 'text-sb-text-1' : 'text-sb-muted',
                        ]}
                      >
                        {item.title}
                      </span>
                    </a>
                  );
                })}
              </div>
            ))}
          </nav>
        </aside>
      </div>

      <Sidebar currentSlug={slug} />

      <!-- Content -->
      <main class="flex-1 min-w-0 overflow-y-auto flex flex-col" id="content-area">
        <div class="flex-1 min-w-0 flex">
          <div class="flex-1 min-w-0">
            <Breadcrumbs title={title} tag={tag} color={color} section={section} />
            <div class="px-8 py-8 max-w-3xl content-fade-in">
              <div class="prose">
                <slot />
              </div>
            </div>

            <!-- Edit on GitHub -->
            <div class="px-8 pb-4 max-w-3xl">
              <a
                href={`https://github.com/Stackbilt-dev/stackbilt-docs/edit/main/src/content/docs/${slug}.md`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[10px] font-terminal text-sb-dim/40 hover:text-sb-amber transition-colors duration-75 tracking-wider"
              >
                EDIT ON GITHUB
              </a>
            </div>

            <PrevNext currentOrder={order} />
          </div>

          <TableOfContents headings={headings} />
        </div>

        <Footer />
      </main>
    </div>

    <!-- Scripts -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // Code copy buttons
        document.querySelectorAll('pre').forEach((pre) => {
          const btn = document.createElement('button');
          btn.className = 'copy-btn';
          btn.textContent = 'COPY';
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code');
            if (code) {
              await navigator.clipboard.writeText(code.textContent || '');
              btn.textContent = 'COPIED';
              setTimeout(() => { btn.textContent = 'COPY'; }, 1500);
            }
          });
          pre.style.position = 'relative';
          pre.appendChild(btn);
        });

        // Search triggers
        ['search-trigger', 'search-trigger-mobile'].forEach(id => {
          const el = document.getElementById(id);
          if (el && window.__searchOpen) {
            el.addEventListener('click', window.__searchOpen);
          }
        });
      });
    </script>
  </body>
</html>
